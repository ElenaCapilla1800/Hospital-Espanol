{# 1. HERENCIA: Importamos la estructura base (cabeceras, menús, scripts comunes) #}
{% extends 'base.html.twig' %}

{% block title %}Gestión de Pacientes - Hospital {% endblock %}

{% block body %}
<div class="container mt-4">
    {# CABECERA DINÁMICA #}
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h1 class="h2 mb-0">📋 Panel de Pacientes</h1>
            <p class="text-muted small">Listado oficial de la base de datos hospitalaria</p>
        </div>

        {# RUTA DINÁMICA: Symfony genera la URL 'paciente/nuevo' automáticamente #}
        <a href="{{ path('app_paciente_nuevo') }}" class="btn btn-primary shadow-sm rounded-pill">
            <i class="fas fa-plus-circle"></i> + Nuevo Registro
        </a>
    </div>

    {# 2. GESTIÓN DE NOTIFICACIONES (MENSAJES FLASH) #}
    {# app.flashes() captura los mensajes enviados desde el PacienteController vía $this->addFlash() #}
    {% for label, mensajes in app.flashes %}
        {% for mensaje in mensajes %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show shadow-sm border-0" role="alert">
                <div class="d-flex align-items-center">
                    <i class="fas fa-check-circle me-2"></i>
                    <div>{{ mensaje }}</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# 3. TABLA DE DATOS CON SOMBRA Y DISEÑO LIMPIO #}
    <div class="card shadow-sm border-0 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-dark text-white text-uppercase small">
                        <tr>
                            <th class="ps-4 py-3" style="width: 80px;">ID</th>
                            <th>Paciente</th>
                            <th>DNI / Identificación</th>
                            <th>Nacimiento</th>
                            <th class="text-center pe-4">Acciones Disponibles</th>
                        </tr>
                    </thead>
                    <tbody>
                    {# 4. BUCLE FOR: Recorremos la colección 'pacientes' enviada por el Controlador #}
                    {% for paciente in pacientes %}
                        <tr>
                            <td class="ps-4">
                                <span class="text-secondary fw-bold">#{{ paciente.id }}</span>
                            </td>
                            <td>
                                {# Usamos los Getters de la Entidad Paciente.php #}
                                <div class="fw-bold text-dark">{{ paciente.nombre }}</div>
                                <div class="small text-muted text-uppercase">{{ paciente.apellidos }}</div>
                            </td>
                            <td>
                                <code class="bg-light px-2 py-1 rounded border text-dark">
                                    {{ paciente.dni }}
                                </code>
                            </td>
                            <td>
                                {# FILTRO |date: Formatea el objeto DateTime de PHP al formato español #}
                                {# Usamos un condicional ternario por si la fecha es NULL #}
                                <i class="far fa-calendar-alt text-muted me-1"></i>
                                {{ paciente.fechaNacimiento ? paciente.fechaNacimiento|date('d/m/Y') : 'Sin fecha' }}
                            </td>
                            <td class="text-center pe-4">
                                <div class="btn-group shadow-sm">
                                    {# BOTÓN VER: Llama al Voter de seguridad y auditoría #}
                                    <a href="{{ path('app_paciente_ver', {'id': paciente.id}) }}"
                                        class="btn btn-outline-info btn-sm"
                                        data-bs-toggle="tooltip" title="Ver ficha clínica">
                                        👁️ Ver
                                    </a>

                                    {# BOTÓN EDITAR: Redirige al formulario de edición #}
                                    <a href="{{ path('app_paciente_editar', {'id': paciente.id}) }}"
                                        class="btn btn-outline-warning btn-sm"
                                        data-bs-toggle="tooltip" title="Modificar datos">
                                        ✏️ Editar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        {# 5. ESTADO VACÍO: Se activa si la variable 'pacientes' no tiene datos #}
                        <tr>
                            <td colspan="5" class="text-center py-5 bg-light">
                                <div class="py-4">
                                    <i class="fas fa-user-slash fa-3x text-light mb-3"></i>
                                    <h5 class="text-muted">No hay pacientes registrados</h5>
                                    <p class="small text-secondary">El sistema está listo para recibir nuevos ingresos.</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
