{# 1. HERENCIA: Mantenemos el diseño global del Hospital #}
{% extends 'base.html.twig' %}

{% block title %}Ficha Médica: {{ paciente.nombre }} {{ paciente.apellidos }}{% endblock %}

{% block body %}
<div class="container mt-4">
    {# CABECERA Y NAVEGACIÓN #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="{{ path('app_paciente_listado') }}" class="btn btn-outline-secondary btn-sm shadow-sm">
            <i class="fas fa-arrow-left"></i> Volver al Listado
        </a>

        {# Acceso rápido a edición desde la propia ficha #}
        <a href="{{ path('app_paciente_editar', {'id': paciente.id}) }}" class="btn btn-warning btn-sm shadow-sm">
            <i class="fas fa-edit"></i> Editar Información
        </a>
    </div>

    <div class="row">
        {# COLUMNA IZQUIERDA: TARJETA DE IDENTIFICACIÓN #}
        <div class="col-lg-4 col-md-5">
            <div class="card shadow border-0 mb-4">
                <div class="card-header bg-primary text-white py-3 text-center">
                    <div class="mb-2">
                        {# Avatar genérico basado en iniciales o icono #}
                        <i class="fas fa-user-circle fa-4x"></i>
                    </div>
                    <h5 class="mb-0 text-uppercase fw-bold">{{ paciente.nombre }}</h5>
                    <small class="opacity-75">{{ paciente.apellidos }}</small>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span class="text-muted"><i class="fas fa-id-card me-2"></i>DNI</span>
                            <span class="fw-bold">{{ paciente.dni }}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span class="text-muted"><i class="fas fa-phone me-2"></i>Teléfono</span>
                            <span>{{ paciente.telefono ?: '<span class="text-danger italic">No registrado</span>'|raw }}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span class="text-muted"><i class="fas fa-birthday-cake me-2"></i>Nacimiento</span>
                            {# Calculamos la edad de forma sencilla con Twig si fuera necesario #}
                            <span>{{ paciente.fechaNacimiento ? paciente.fechaNacimiento|date('d/m/Y') : 'N/A' }}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 border-bottom-0">
                            <span class="text-muted"><i class="fas fa-clock me-2"></i>ID Registro</span>
                            <span class="badge bg-light text-dark border">#{{ paciente.id }}</span>
                        </li>
                    </ul>
                </div>
                <div class="card-footer bg-light text-center py-2">
                    <small class="text-muted italic">Datos protegidos por Ley de Privacidad</small>
                </div>
            </div>
        </div>

        {# COLUMNA DERECHA: INFORMACIÓN CLÍNICA SENSIBLE #}
        <div class="col-lg-8 col-md-7">
            <div class="card shadow border-0 h-100">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
                    <h5 class="mb-0"><i class="fas fa-notes-medical me-2 text-info"></i>Historial Clínico</h5>
                    <span class="badge bg-danger">ACCESO RESTRINGIDO</span>
                </div>
                <div class="card-body bg-white">
                    {% if paciente.historialClinico %}
                        <div class="p-4 bg-light border-start border-info border-4 rounded">
                            {# 2. SEGURIDAD Y FORMATO: nl2br para los saltos de línea y escape de HTML por defecto #}
                            <p class="mb-0 lh-lg" style="white-space: pre-wrap;">{{ paciente.historialClinico }}</p>
                        </div>
                    {% else %}
                        <div class="text-center py-5">
                            <i class="fas fa-file-medical-alt fa-3x text-light mb-3"></i>
                            <p class="text-muted">No existen anotaciones médicas previas para este paciente.</p>
                            <p class="small">Use el botón de edición para añadir antecedentes.</p>
                        </div>
                    {% endif %}
                </div>

                {# 3. ESPACIO PARA FUTURAS AMPLIACIONES: VISITAS O RECETAS #}
                <div class="card-footer bg-white border-top-0 p-4">
                    <h6 class="border-bottom pb-2 mb-3 text-secondary text-uppercase small fw-bold">Próximos Pasos</h6>
                    <div class="d-grid gap-2 d-md-block">
                        <button class="btn btn-outline-primary btn-sm disabled"><i class="fas fa-calendar-plus me-1"></i> Programar Cita</button>
                        <button class="btn btn-outline-info btn-sm disabled"><i class="fas fa-prescription me-1"></i> Nueva Receta</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
