{# templates/admin/export/pdf.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: sans-serif; font-size: 12px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #333; padding: 8px; text-align: left; }
        th { background-color: #f2f2f2; }
        .header { text-align: center; margin-bottom: 30px; }
        .footer { position: fixed; bottom: 0; width: 100%; text-align: right; font-size: 10px; }
    </style>
</head>
<body>
    <div class="header">
        <h1 style="color: #d9534f;">Informe de Accesos Sospechosos (24h)</h1>
        <p>Hospital Español - Sistema de Auditoría</p>
    </div>

    <table>
        <thead>
            <tr>
                <th>Fecha y Hora</th>
                <th>Usuario (Email)</th>
                <th>Acción Realizada</th>
                <th>IP de Origen</th>
            </tr>
        </thead>
        <tbody>
            {% for alerta in alertas %}
                <tr>
                    <td>{{ alerta.fecha|date('d/m/Y H:i:s') }}</td>
                    {# AQUÍ ESTABA EL ERROR: Cambiado de .usuario a .usuarioEmail #}
                    <td><strong>{{ alerta.usuarioEmail }}</strong></td>
                    <td>{{ alerta.accion }}</td>
                    <td><code>{{ alerta.ip }}</code></td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="footer">
        Generado el {{ fecha|date('d/m/Y H:i') }}
    </div>
</body>
</html>
